<div class="music-page-wrapper">
  
  <!-- Search Header -->
  <div class="music-header">
    <div class="hero-badge" style="margin-bottom: 1rem;"><i class="fa-solid fa-music"></i> Vermeil Stream</div>
    <h1>Premium Web Player</h1>
    <div class="music-search-section">
      <div class="search-bar">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input type="text" id="music-query" placeholder="Search for songs, artists, or links..." onkeydown="if(event.key==='Enter') searchMusic()">
        <button class="btn btn-primary" onclick="searchMusic()" style="position: absolute; right: 8px; top: 8px; padding: 8px 20px; font-size: 0.85rem;">Search</button>
      </div>
    </div>
  </div>

  <!-- Discovery Section -->
  <div id="discovery-section">
    <div class="section-title">
      <h3><i class="fa-solid fa-sparkles"></i> Curated Discovery</h3>
      <p>Quickly play top hits and curated vibes.</p>
    </div>
    
    <div class="discovery-grid">
      <div class="discovery-card" onclick="playCurated('Lo-fi Hip Hop Beats')">
        <div class="discovery-thumb" style="background: linear-gradient(135deg, #FF9A8B 0%, #FF6A88 55%, #FF99AC 100%);">
          <i class="fa-solid fa-mug-hot"></i>
        </div>
        <h4>Lo-fi Vibes</h4>
        <p>Perfect for study & work</p>
      </div>
      <div class="discovery-card" onclick="playCurated('Top Global Hits 2026')">
        <div class="discovery-thumb" style="background: linear-gradient(135deg, #8BC6EC 0%, #9599E2 100%);">
          <i class="fa-solid fa-globe"></i>
        </div>
        <h4>Top Global</h4>
        <p>What's trending now</p>
      </div>
      <div class="discovery-card" onclick="playCurated('Phonk Mix 2026')">
        <div class="discovery-thumb" style="background: linear-gradient(135deg, #21D4FD 0%, #B721FF 100%);">
          <i class="fa-solid fa-bolt"></i>
        </div>
        <h4>Phonk Mix</h4>
        <p>High energy drift</p>
      </div>
      <div class="discovery-card" onclick="playCurated('Synthwave / Retrowave')">
        <div class="discovery-thumb" style="background: linear-gradient(135deg, #FAD961 0%, #F76B1C 100%);">
          <i class="fa-solid fa-user-astronaut"></i>
        </div>
        <h4>Retro Space</h4>
        <p>Synthwave nostalgia</p>
      </div>
    </div>

    <!-- Suggested Songs -->
    <div class="section-title" style="margin-top: 3rem;">
      <h3><i class="fa-solid fa-list-music"></i> Popular Tracks</h3>
    </div>
    <div class="popular-tracks" id="popular-tracks">
      <div class="track-row" onclick="playCurated('Nightcall - Kavinsky')">
        <img src="https://i.ytimg.com/vi/MV_3Dpw-BRY/hqdefault.jpg" alt="">
        <div class="track-info">
          <span class="track-name">Nightcall</span>
          <span class="track-author">Kavinsky</span>
        </div>
        <div class="track-play"><i class="fa-solid fa-play"></i></div>
      </div>
      <div class="track-row" onclick="playCurated('After Hours - The Weeknd')">
        <img src="https://i.ytimg.com/vi/ygTZZpVNJ44/hqdefault.jpg" alt="">
        <div class="track-info">
          <span class="track-name">After Hours</span>
          <span class="track-author">The Weeknd</span>
        </div>
        <div class="track-play"><i class="fa-solid fa-play"></i></div>
      </div>
      <div class="track-row" onclick="playCurated('Blinding Lights - The Weeknd')">
        <img src="https://i.ytimg.com/vi/fHI8X4OXluQ/hqdefault.jpg" alt="">
        <div class="track-info">
          <span class="track-name">Blinding Lights</span>
          <span class="track-author">The Weeknd</span>
        </div>
        <div class="track-play"><i class="fa-solid fa-play"></i></div>
      </div>
    </div>
  </div>

  <!-- Search Results -->
  <div id="search-results-section" style="display: none;">
    <div class="section-title">
      <button class="btn btn-outline" style="padding: 5px 15px; margin-bottom: 1rem;" onclick="backToDiscovery()">
        <i class="fa-solid fa-chevron-left"></i> Back to Discovery
      </button>
      <h3>Search Results</h3>
    </div>
    <div class="results-grid" id="results-grid"></div>
  </div>

</div>

<!-- Persistent Bottom Player -->
<div class="music-player-bar">
  <div class="player-progress">
    <div class="progress-filled" id="player-progress-bar" style="width: 0%;"></div>
  </div>
  
  <div class="player-content">
    <div class="player-track">
      <img src="<%= config.botLogo %>" id="player-thumb" alt="">
      <div class="player-track-info">
        <span class="track-title" id="player-title">Not Playing</span>
        <span class="track-artist" id="player-author">Select a song to start</span>
      </div>
    </div>

    <div class="player-controls">
      <button class="control-btn" id="btn-prev" onclick="playPrev()"><i class="fa-solid fa-backward-step"></i></button>
      <button class="control-btn play-main" id="btn-play" onclick="togglePlay()"><i class="fa-solid fa-play"></i></button>
      <button class="control-btn" id="btn-next" onclick="playNext()"><i class="fa-solid fa-forward-step"></i></button>
    </div>

    <div class="player-actions">
      <div class="volume-control">
        <i class="fa-solid fa-volume-high"></i>
        <input type="range" id="volume-slider" min="0" max="100" value="80" oninput="updateVolume(this.value)">
      </div>
    </div>
  </div>
</div>

<!-- Hidden Audio Engine (YouTube Iframe) -->
<div id="youtube-engine" style="display:none"></div>

<style>
.music-page-wrapper {
  padding: 100px 5% 150px;
  max-width: 1200px;
  margin: 0 auto;
}

.music-header { text-align: center; margin-bottom: 4rem; }
.music-header h1 { font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 900; margin-bottom: 1.5rem; }

.music-search-section {
  display: flex;
  justify-content: center;
  max-width: 700px;
  margin: 0 auto;
}

.search-bar { position: relative; width: 100%; }
.search-bar input {
  width: 100%;
  background: var(--bg-card);
  border: 2px solid var(--border);
  padding: 1.2rem 1.5rem 1.2rem 3.5rem;
  border-radius: 16px;
  color: #fff;
  font-size: 1.1rem;
  outline: none;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}
.search-bar input:focus { border-color: var(--accent); box-shadow: 0 0 30px var(--accent-glow); }
.search-icon { position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 1.2rem; }

.section-title { margin-bottom: 2rem; }
.section-title h3 { font-size: 1.5rem; font-weight: 800; display: flex; align-items: center; gap: 10px; }
.section-title h3 i { color: var(--accent); }
.section-title p { color: var(--text-muted); margin-top: 5px; }

/* ── Discovery Grid ──────────────────────────────────── */
.discovery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 20px;
}

.discovery-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 20px;
  border-radius: 20px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: center;
}

.discovery-card:hover { transform: translateY(-10px); border-color: var(--accent); background: var(--accent-glow); }

.discovery-thumb {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16px;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
  color: #fff;
  box-shadow: 0 10px 20px rgba(0,0,0,0.3);
}

.discovery-card h4 { font-weight: 800; margin-bottom: 5px; }
.discovery-card p { font-size: 0.85rem; color: var(--text-muted); }

/* ── Popular Tracks ──────────────────────────────────── */
.popular-tracks { display: flex; flex-direction: column; gap: 10px; }
.track-row {
  display: flex;
  align-items: center;
  gap: 15px;
  padding: 12px 20px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.2s ease;
}
.track-row:hover { border-color: var(--accent-blue); background: rgba(255,255,255,0.05); transform: translateX(5px); }
.track-row img { width: 50px; height: 50px; border-radius: 8px; object-fit: cover; }
.track-info { flex: 1; display: flex; flex-direction: column; }
.track-name { font-weight: 700; color: #fff; }
.track-author { font-size: 0.85rem; color: var(--text-muted); }
.track-play { font-size: 1.2rem; color: var(--accent-blue); opacity: 0.5; transition: 0.2s; }
.track-row:hover .track-play { opacity: 1; transform: scale(1.1); }

/* ── Search Results Grid ─────────────────────────────── */
.results-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}
.result-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
}
.result-item:hover { border-color: var(--accent); transform: translateY(-5px); }
.result-thumb { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
.result-content { padding: 15px; }
.result-title { font-weight: 700; color: #fff; margin-bottom: 5px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.result-author { font-size: 0.85rem; color: var(--text-muted); }

/* ── Bottom Player Bar ───────────────────────────────── */
.music-player-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(13, 17, 23, 0.95);
  backdrop-filter: blur(20px);
  border-top: 1px solid var(--border);
  z-index: 1000;
}

.player-progress {
  width: 100%;
  height: 4px;
  background: rgba(255,255,255,0.1);
  cursor: pointer;
  position: relative;
}
.progress-filled { height: 100%; background: var(--accent); position: relative; }
.progress-filled::after { content: ''; position: absolute; right: -5px; top: -3px; width: 10px; height: 10px; background: #fff; border-radius: 50%; box-shadow: 0 0 10px var(--accent); opacity: 0; transition: opacity 0.2s; }
.player-progress:hover .progress-filled::after { opacity: 1; }

.player-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15px 5%;
  height: 90px;
}

.player-track { display: flex; align-items: center; gap: 15px; width: 30%; }
.player-track img { width: 60px; height: 60px; border-radius: 12px; object-fit: cover; border: 1px solid var(--border); }
.player-track-info { display: flex; flex-direction: column; min-width: 0; }
.track-title { font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.track-artist { font-size: 0.85rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.player-controls { display: flex; align-items: center; gap: 2rem; }
.control-btn { background: none; border: none; color: #fff; font-size: 1.4rem; cursor: pointer; transition: 0.2s; opacity: 0.7; }
.control-btn:hover { opacity: 1; color: var(--accent); }
.play-main { width: 50px; height: 50px; background: #fff; color: #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; opacity: 1; }
.play-main:hover { transform: scale(1.1); background: var(--accent); color: #fff; }

.player-actions { width: 30%; display: flex; justify-content: flex-end; }
.volume-control { display: flex; align-items: center; gap: 10px; width: 150px; }
.volume-control i { color: var(--text-muted); }
.volume-control input { flex: 1; accent-color: var(--accent); height: 4px; cursor: pointer; }

@media (max-width: 768px) {
  .player-track { width: 70%; }
  .player-actions, .player-controls #btn-prev, .player-controls #btn-next { display: none; }
  .player-content { padding: 10px 20px; }
}
</style>

<script src="https://www.youtube.com/iframe_api"></script>
<script>
let player;
let currentTrack = null;
let playlist = [];
let progressInterval;

// YT API Ready
function onYouTubeIframeAPIReady() {
  player = new YT.Player('youtube-engine', {
    height: '0',
    width: '0',
    videoId: '',
    events: {
      'onStateChange': onPlayerStateChange
    }
  });
}

function onPlayerStateChange(event) {
  const btn = document.getElementById('btn-play');
  if (event.data == YT.PlayerState.PLAYING) {
    btn.innerHTML = '<i class="fa-solid fa-pause"></i>';
    startProgress();
  } else if (event.data == YT.PlayerState.ENDED) {
    playNext();
  } else {
    btn.innerHTML = '<i class="fa-solid fa-play"></i>';
    clearInterval(progressInterval);
  }
}

function startProgress() {
  clearInterval(progressInterval);
  progressInterval = setInterval(() => {
    if (player && player.getDuration) {
      const current = player.getCurrentTime();
      const duration = player.getDuration();
      const perc = (current / duration) * 100;
      document.getElementById('player-progress-bar').style.width = perc + '%';
    }
  }, 1000);
}

// Search Logic
async function searchMusic() {
  const q = document.getElementById('music-query').value;
  if (!q) return;

  const btn = event?.target?.tagName === 'BUTTON' ? event.target : document.querySelector('.music-search-section button');
  btn.innerText = '...';

  try {
    const res = await fetch(`/api/music/search?q=${encodeURIComponent(q)}`);
    const data = await res.json();
    
    if (data.tracks) {
      playlist = data.tracks;
      renderResults(data.tracks);
      document.getElementById('discovery-section').style.display = 'none';
      document.getElementById('search-results-section').style.display = 'block';
    }
  } catch (err) {
    alert('Search failed. Check your connection.');
  } finally {
    btn.innerText = 'Search';
  }
}

function renderResults(tracks) {
  const grid = document.getElementById('results-grid');
  grid.innerHTML = tracks.map((t, i) => `
    <div class="result-item" onclick="playTrack(${i})">
      <img src="${t.thumbnail}" class="result-thumb">
      <div class="result-content">
        <div class="result-title">${t.title}</div>
        <div class="result-author">${t.author}</div>
      </div>
    </div>
  `).join('');
}

function backToDiscovery() {
  document.getElementById('discovery-section').style.display = 'block';
  document.getElementById('search-results-section').style.display = 'none';
}

async function playCurated(q) {
  const res = await fetch(`/api/music/search?q=${encodeURIComponent(q)}`);
  const data = await res.json();
  if (data.tracks && data.tracks.length > 0) {
    playlist = data.tracks;
    playTrack(0);
  }
}

function playTrack(index) {
  currentTrack = playlist[index];
  if (!currentTrack) return;

  // Update UI
  document.getElementById('player-title').innerText = currentTrack.title;
  document.getElementById('player-author').innerText = currentTrack.author;
  document.getElementById('player-thumb').src = currentTrack.thumbnail;

  // Play in engine
  player.loadVideoById(currentTrack.identifier);
}

function togglePlay() {
  if (!player) return;
  const state = player.getPlayerState();
  if (state === YT.PlayerState.PLAYING) {
    player.pauseVideo();
  } else {
    player.playVideo();
  }
}

function playNext() {
  const idx = playlist.indexOf(currentTrack);
  if (idx !== -1 && idx < playlist.length - 1) playTrack(idx + 1);
}

function playPrev() {
  const idx = playlist.indexOf(currentTrack);
  if (idx > 0) playTrack(idx - 1);
}

function updateVolume(val) {
  if (player) player.setVolume(val);
}
</script>
