<section class="changelog-page" style="max-width: 900px; margin: 0 auto; padding: 6rem 2rem;">
  <div class="section-header" style="text-align: left; margin-bottom: 4rem;">
    <span class="section-tag">Updates</span>
    <h1 style="font-size: 3rem; margin-top: 1rem;">Changelog</h1>
    <p style="margin: 1.5rem 0 0;">Keep track of the latest additions, improvements, and fixes for <%= config.botName %>.</p>
  </div>

  <div class="docs-content" style="margin-left: 0; padding: 0; max-width: 100%;">
    <%- content %>
  </div>
</section>