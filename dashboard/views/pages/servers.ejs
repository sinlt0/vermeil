<div class="page-header">
  <div class="page-header-row">
    <div>
      <h1>Select a Server</h1>
      <p>Choose a server to manage its settings and features.</p>
    </div>
  </div>
</div>

<div class="servers-grid">
  <% guilds.forEach(g => { %>
    <% if (g.botPresent) { %>
      <a href="/dashboard/<%= g.id %>" class="server-card">
        <% if (g.icon) { %>
          <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" alt="<%= g.name %>">
        <% } else { %>
          <div class="server-icon-placeholder"><%= g.name.charAt(0) %></div>
        <% } %>
        <h3><%= g.name %></h3>
        <p class="badge badge-green">Manage Server</p>
      </a>
    <% } else { %>
      <a href="<%= config.inviteLink %>&guild_id=<%= g.id %>" target="_blank" class="server-card" style="opacity: 0.7;">
        <% if (g.icon) { %>
          <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" alt="<%= g.name %>" style="filter: grayscale(1);">
        <% } else { %>
          <div class="server-icon-placeholder"><%= g.name.charAt(0) %></div>
        <% } %>
        <h3><%= g.name %></h3>
        <p class="badge badge-grey">Invite Bot</p>
      </a>
    <% } %>
  <% }); %>
</div>

<% if (guilds.length === 0) { %>
  <div class="empty-state">
    <i class="fa-solid fa-server"></i>
    <h3>No manageable servers found</h3>
    <p>You need "Manage Server" permissions to configure a guild.</p>
  </div>
<% } %>