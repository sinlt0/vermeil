# ── Bot Token ───────────────────────────────────────────
TOKEN=your_discord_bot_token

# ── MongoDB Configuration ───────────────────────────────
# NOTE: We do NOT recommend adding a MongoDB URI here.
# Adding it here will override config.js and DISABLE multi-cluster support.
# Use this ONLY for simple single-cluster setups.
MONGODB_URI=

# ── Webhooks (Logging) ──────────────────────────────────
# Add your Discord webhook URLs here for premium logging.
LOG_CONSOLE_WEBHOOK=
LOG_ERRORS_WEBHOOK=
LOG_COMMANDS_WEBHOOK=
LOG_DATABASE_WEBHOOK=

# ── Dashboard (OAuth2) ──────────────────────────────────
# Values must match your webconfig.js and Discord Dev Portal
CLIENT_ID=
CLIENT_SECRET=
